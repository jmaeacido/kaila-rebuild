APP_NAME=KAILA
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
KAILA_ADMIN_ORIGIN=http://localhost:3001
KAILA_WEB_ORIGINS=http://localhost:3000,http://localhost:3001
MAPS_PROVIDER=fake
NOMINATIM_URL=http://127.0.0.1:8080
OSRM_URL=http://127.0.0.1:5000
MAPS_REQUEST_TIMEOUT_SECONDS=5
FCM_TRANSPORT=fake
FCM_PROJECT_ID=
FCM_ACCESS_TOKEN=
FCM_SERVICE_ACCOUNT_PATH=

MOBILE_ACCESS_TOKEN_TTL_MINUTES=15
MOBILE_REFRESH_TOKEN_TTL_DAYS=30
REALTIME_TICKET_TTL_SECONDS=60
REALTIME_TICKET_SIGNING_SEED_BASE64=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=kaila
DB_USERNAME=kaila
DB_PASSWORD=change-this-local-password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
PRIVATE_ASSET_DISK=private-assets
QUEUE_CONNECTION=redis
OUTBOX_DISPATCH_BATCH_SIZE=100
OUTBOX_PROCESSING_TIMEOUT_SECONDS=300
OUTBOX_TRANSPORT=redis-realtime
OUTBOX_REALTIME_CHANNEL=kaila:realtime:events

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6380

TERMS_VERSION=2026-07-16
PRIVACY_VERSION=2026-07-16

MAIL_MAILER=log
BREVO_API_KEY=
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=http://127.0.0.1:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"

# Phase 9 modules are independently reversible. Calls remain unavailable until
# all managed TURN credentials are provided and PHASE_NINE_CALLS is enabled.
PHASE_NINE_ENABLED=true
PHASE_NINE_DIRECT_MESSAGES=true
PHASE_NINE_CALLS=false
PHASE_NINE_COMMUNITY=true
PHASE_NINE_KATABANG=true
PHASE_NINE_ANALYTICS=true
ANALYTICS_MINIMUM_COHORT=10
WEBRTC_TURN_URL=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_CREDENTIAL=
